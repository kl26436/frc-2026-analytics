rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Access Config & Requests ──
    match /config/{docId} {
      // Anyone authenticated can read (needed to check allowlist on login)
      allow read: if request.auth != null;

      // accessRequests doc: any authenticated user can write
      // (so non-allowlisted users can submit a request, admins can approve/deny)
      allow write: if request.auth != null
                   && docId == 'accessRequests';

      // liveSession doc: admins can create/update/delete (broadcast live alliance sessions)
      allow write: if request.auth != null
                   && docId == 'liveSession'
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;

      // eventConfig doc: admins only (broadcast active event + home team to all users)
      allow write: if request.auth != null
                   && docId == 'eventConfig'
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;

      // syncMeta doc: admins only (written by sync script / Cloud Function)
      allow write: if request.auth != null
                   && docId == 'syncMeta'
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;

      // userProfiles doc: any allowed user can write (sign-in upsert) or admin can write (manual name edit)
      allow write: if request.auth != null
                   && docId == 'userProfiles'
                   && (request.auth.token.email in
                         get(/databases/$(database)/documents/config/access).data.allowedEmails
                       || request.auth.token.email in
                         get(/databases/$(database)/documents/config/access).data.adminEmails);

      // access doc: bootstrap — first user can create if it doesn't exist yet
      allow create: if request.auth != null
                    && docId == 'access'
                    && !exists(/databases/$(database)/documents/config/access);

      // access doc: only admins can update or delete
      allow update, delete: if request.auth != null
                            && docId == 'access'
                            && request.auth.token.email in resource.data.adminEmails;
    }

    // ── Alliance Selection Sessions ──
    match /sessions/{sessionId} {
      // Any authenticated user can read (they need the sessionId/code to access)
      allow read: if request.auth != null;

      // Only the creator can create
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // Any authenticated user can update (joining adds them to participants,
      // editors/host make game-state changes — all require write access)
      allow update: if request.auth != null;

      // Only creator can delete
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }

    // ── Pit Scouting ──
    match /pitScouting/{entryId} {
      // Any authenticated user can read/write pit scouting data
      allow read, write: if request.auth != null;
    }

    // ── Live Pick List ──
    match /pick-lists/{eventKey} {
      allow read: if request.auth != null && (
        request.auth.token.email in get(/databases/$(database)/documents/config/access).data.allowedEmails ||
        request.auth.token.email in get(/databases/$(database)/documents/config/access).data.adminEmails
      );
      allow write: if request.auth != null &&
        request.auth.token.email in get(/databases/$(database)/documents/config/access).data.adminEmails;
    }

    match /pick-lists/{eventKey}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /pick-lists/{eventKey}/suggestions/{suggestionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null; // voting + admin accept/dismiss
    }

    // ── Synced Scouting Data (Postgres → Firestore) ──
    match /scoutData/{eventKey}/entries/{entryId} {
      allow read: if request.auth != null;
      // Writes come from Cloud Functions (Admin SDK bypasses rules) or admin users
      allow write: if request.auth != null
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;
    }

    // ── Synced Scout Actions (Postgres → Firestore) ──
    match /scoutActions/{eventKey}/actions/{actionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;
    }

    // ── Synced TBA Data (Postgres → Firestore) ──
    match /tbaData/{eventKey}/matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;
    }

    match /tbaData/{eventKey}/rankings/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in
                      get(/databases/$(database)/documents/config/access).data.adminEmails;
    }

    // ── Sync Metadata ──
    // (Handled by existing /config/{docId} rules — syncMeta is a config doc)
  }
}
